rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function userTeamId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('teamId', null);
    }

    function isTeamBidder() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'user' &&
        userTeamId() is string;
    }

    function canAccessTeamScopedData(teamId) {
      return signedIn() && (isAdmin() || userTeamId() == teamId);
    }

    function validTeamBidUpdate() {
      let teamDoc = get(/databases/$(database)/documents/teams/$(userTeamId())).data;
      return request.resource.data.currentBid > resource.data.currentBid &&
        teamDoc.get('remainingPoints', 0) >= request.resource.data.currentBid &&
        request.resource.data.leadingTeam.id == userTeamId();
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid && 
                    (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'user');
      allow update: if signedIn() && (
        isAdmin() || 
        (request.auth.uid == uid && request.resource.data.get('role', 'user') == resource.data.get('role', 'user'))
      );
      allow delete: if signedIn() && isAdmin();
    }

    match /players/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /teams/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /auction/{docId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if signedIn() && (
        isAdmin() || 
        (docId == 'current' && isTeamBidder())
      );
    }

    match /auction_results/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /matches/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /team_watchlists/{teamId} {
      allow read, write: if canAccessTeamScopedData(teamId);

      match /items/{playerId} {
        allow read, write: if canAccessTeamScopedData(teamId);
      }
    }

    match /team_budget_plans/{teamId} {
      allow read, write: if canAccessTeamScopedData(teamId);
    }

    match /team_notes/{teamId} {
      allow read, write: if canAccessTeamScopedData(teamId);

      match /players/{playerId} {
        allow read, write: if canAccessTeamScopedData(teamId);
      }
    }
  }
}
