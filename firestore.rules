rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function userTeamId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId;
    }

    function isTeamBidder() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'user' &&
        userTeamId() is string;
    }

    function validTeamBidUpdate() {
      return request.resource.data.currentBid is int &&
        request.resource.data.currentBid > resource.data.currentBid &&
        request.resource.data.isAuctionActive == true &&
        resource.data.isAuctionActive == true &&
        request.resource.data.timeRemaining == 30 &&
        request.resource.data.currentPlayer == resource.data.currentPlayer &&
        request.resource.data.leadingTeam.id == userTeamId();
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /players/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /teams/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /auction/{docId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (docId == 'current' && isTeamBidder() && validTeamBidUpdate());
    }

    match /auction_results/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /matches/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
